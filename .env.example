# Porta HTTP. O Backend usa GRUPO_FLOW_SERVICE_URL apontando para este serviço.
PORT=4334

# Evolution GO — host sem barra (ex.: evogo.clerky.com.br) ou URL completa https://...
EVOLUTION_HOST=evogo.clerky.com.br
# Chave global admin (opcional; operações usam token da instância no header apikey)
EVOLUTION_APIKEY=

# Mesmo segredo do JWT do Backend (GRUPO_FLOW_INTERNAL_KEY nos dois lados)
GRUPO_FLOW_INTERNAL_KEY=

# Origens CORS separadas por vírgula (vazio = localhost + onlyflow.com.br)
CORS_ORIGINS=

# true = não validar TLS (só dev/homolog)
EVOLUTION_INSECURE_TLS=false

# false = não chama POST /group/settings na GO (anúncio/bloqueio); use enquanto a GO não registra a rota (issue #42)
# EVOLUTION_GROUP_SETTINGS_ENABLED=false
