# Porta do microserviço (Backend usa GROUP_SERVICE_URL / GROUP_FLOW_URL apontando para aqui)
PORT=4334

# Evolution API — base URL sem barra final (ex: https://evo.seudominio.com)
EVOLUTION_API_BASE_URL=https://evo.example.com

# Chave global da Evolution (header apikey)
EVOLUTION_API_KEY=

# Mesmo segredo do JWT do Backend OnlyFlow (ou chave dedicada se o Backend usar GROUP_FLOW_INTERNAL_KEY)
GRUPO_FLOW_INTERNAL_KEY=

# Opcional: origens CORS separadas por vírgula. Se vazio, reflete a origem quando for localhost ou *.onlyflow.com.br
CORS_ORIGINS=

# true = axios não valida certificado TLS (só dev/homologação)
EVOLUTION_INSECURE_TLS=false
