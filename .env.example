# Porta HTTP local do microserviço. Em produção o Backend chama a URL pública (ex.: https://gpc-sandbox.onlyflow.com.br).
PORT=4334

# Evolution API — base URL sem barra final (ex: https://evo.seudominio.com)
EVOLUTION_API_BASE_URL=https://evo.example.com

# Chave global da Evolution (header apikey)
EVOLUTION_API_KEY=

# Mesmo valor que GRUPO_FLOW_INTERNAL_KEY no .env do Backend OnlyFlow (header x-internal-key nas rotas /internal).
GRUPO_FLOW_INTERNAL_KEY=

# Opcional: origens permitidas, separadas por vírgula. Devem ser iguais ao header Origin do browser (com https:// ou http://, e porta se não for 443/80). Ex: https://app.onlyflow.com.br,http://localhost:5173. Se vazio, usa regra padrão (localhost / onlyflow.com.br).
CORS_ORIGINS=

# true = axios não valida certificado TLS (só dev/homologação)
EVOLUTION_INSECURE_TLS=false
